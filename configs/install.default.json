{
  "runtime": {
    "min_nofile": 65536,
    "shutdown_grace_ms": 2000
  },
  "http": {
    "listen": "0.0.0.0:8080",
    "upstream": "http://127.0.0.1:9000",
    "preserve_host": true,
    "allowed_methods": ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "require_host_header": true,
    "max_host_bytes": 255,
    "allowed_hosts": [],
    "listen_backlog": 4096,
    "accept_shards": 4,
    "max_header_bytes": 32768,
    "max_header_line_bytes": 8192,
    "max_headers": 100,
    "max_uri_bytes": 8192,
    "max_query_bytes": 4096,
    "max_query_pairs": 128,
    "max_path_segments": 64,
    "header_read_timeout_ms": 5000,
    "downstream_keep_alive": false,
    "downstream_write_timeout_ms": 15000,
    "upstream_timeout_ms": 15000,
    "upstream_connect_timeout_ms": 1000,
    "upstream_failure_threshold": 8,
    "upstream_failure_open_ms": 1000,
    "upstream_pool_idle_timeout_ms": 30000,
    "upstream_pool_max_idle_per_host": 256,
    "upstream_max_header_bytes": 32768,
    "upstream_max_header_line_bytes": 8192,
    "upstream_max_headers": 100,
    "upstream_body_idle_timeout_ms": 15000,
    "max_upstream_body_bytes": 104857600,
    "upstream_body_min_rate_bytes_per_second": 512,
    "upstream_body_min_rate_grace_ms": 10000,
    "max_connection_duration_seconds": 120,
    "max_requests_per_connection": 1000,
    "max_body_bytes": 10485760,
    "request_body_idle_timeout_ms": 10000,
    "request_body_min_rate_bytes_per_second": 512,
    "request_body_min_rate_grace_ms": 10000,
    "allow_compressed_request_bodies": false,
    "allow_chunked_request_bodies": false,
    "allow_expect_continue": false,
    "max_ranges": 1,
    "forward_accept_encoding": false,
    "forward_request_trailers": false,
    "max_trailer_bytes": 8192,
    "max_trailers": 32,
    "forward_response_trailers": false,
    "upstream_max_trailer_bytes": 8192,
    "upstream_max_trailers": 32,
    "client_ip": {
      "header": "x-forwarded-for",
      "trusted_proxies": [],
      "max_forwarded_for_bytes": 1024,
      "max_forwarded_for_hops": 32
    },
    "limits": {
      "per_ip_rps": 250,
      "per_ip_burst": 500,
      "ipv4_prefix_len": 32,
      "ipv6_prefix_len": 64,
      "global_rps": 20000,
      "global_burst": 40000,
      "trusted_proxy_rps": 5000,
      "trusted_proxy_burst": 10000,
      "trusted_proxy_max_in_flight_requests": 4096,
      "signature_rps": 5000,
      "signature_burst": 10000,
      "max_tracked_signatures": 8192,
      "path_shape_rps": 10000,
      "path_shape_burst": 20000,
      "max_tracked_path_shapes": 4096,
      "per_ip_connects_per_second": 100,
      "per_ip_connect_burst": 200,
      "global_connects_per_second": 20000,
      "global_connect_burst": 40000,
      "max_connections": 10000,
      "max_connections_per_ip": 1024,
      "max_in_flight_requests": 8192,
      "max_in_flight_requests_per_ip": 512,
      "max_tracked_ips": 65536
    }
  },
  "tcp": [],
  "filters": {
    "runtime_file": "runtime/filters.json",
    "reload_seconds": 2,
    "max_runtime_file_bytes": 1048576,
    "max_runtime_filters": 1024,
    "max_static_filters": 1024,
    "static_rules": []
  },
  "adaptive": {
    "enabled": true,
    "signature_threshold_per_second": 300,
    "activation_ttl_seconds": 60,
    "event_log": "runtime/attack_events.jsonl",
    "event_log_flush_interval_ms": 100,
    "event_log_max_bytes": 67108864,
    "event_log_backup_count": 2,
    "event_log_queue_capacity": 4096,
    "event_cooldown_seconds": 5,
    "max_signature_windows": 8192,
    "max_path_shape_windows": 8192
  }
}